{
  "_README": {
    "about": "OLDSECTOR component presets edited in the in-game EDIT screen. Live working copy is mirrored to localStorage 'oldsector_editPresets'; this file is the seed/default and the canonical export format (use the EXPORT JSON button to copy edits back here).",
    "units": {
      "engine.coreSpeed/envSpeed": "exhaust ejection speed in screen px/frame (base; a small random variance is added at spawn)",
      "engine.coreLife/envLife": "particle lifetime in frames (length of the plume)",
      "engine.coreSize/envSize": "base particle radius (multiplied by the renderer fade ramp)",
      "engine.coreScatter/envScatter": "lateral spread of the jet (0 = collimated)",
      "engine.brightness": "additive alpha multiplier of the whole plume",
      "engine.flashIntensity": "brightness of the flickering blue point-light at the nozzle cluster",
      "engine.emitRate": "particles emitted per frame at full thrust",
      "projectile.speed": "world units / frame",
      "projectile.radius": "collision radius / hull-impact size",
      "projectile.life": "frames before the round expires (range)",
      "projectile.glowSize/coreSize": "rendered streak widths in px",
      "projectile.tail": "streak tail length multiplier",
      "turret.barrels": "number of muzzles",
      "turret.fireMode": "'sequential' = one barrel after another, 'volley' = all barrels at once",
      "turret.spreadPct": "shot dispersion as a percent",
      "turret.arcDeg": "total fire arc the turret can traverse (degrees)",
      "turret.turnSpeed": "traverse speed (degrees / second)",
      "turret.reload": "seconds between bursts",
      "turret.magazine": "rounds per magazine before a longer reload",
      "turret.projId": "id of the projectile preset this turret fires",
      "hull.engineId": "engine preset whose particle params drive every engine slot on this hull",
      "hull.turretSlots": "explicit, draggable weapon mounts: [{id, x, y, size, turretId}]. x=forward (>0 nose), y=lateral, both fractions of the sprite quad from hull center. size = 'S'|'M'|'L'. turretId = turret preset (null=empty).",
      "hull.engineSlots": "explicit, draggable exhaust nozzles: [{id, x, y, size}]. Same coordinate space; flames spawn here using engineId's params.",
      "hull.material": "{color: hex tint, metal: 0..1 metallic, rough: 0..1 roughness} fed to the PBR sprite shader (uTint/uMetal/uRough).",
      "beam.mode": "'continuous' = sustained ray that charges up and holds on target; 'pulse' = rapid blinking ray that flashes on for pulseLen then reloads",
      "beam.reach": "max beam length / engagement range in world units",
      "beam.damage": "continuous = damage-per-second; pulse = damage per flash",
      "beam.coreWidth/glowWidth": "rendered beam widths in px (bright inner spine + soft outer glow)",
      "beam.chargeUp": "continuous only — seconds from first fire to full-power beam",
      "beam.pulseRate": "pulse only — flashes per second",
      "beam.pulseLen": "pulse only — on-time of each flash in ms",
      "beam.flicker": "intensity jitter in Hz (visual shimmer)",
      "beam.selfFluxPct": "percent of dealt damage added to the shooter's own flux"
    }
  },
